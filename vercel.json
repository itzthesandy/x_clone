{
    "version": 2,
    "buildCommand": "npm install && npm install --include=dev --prefix frontend && npm run build --prefix frontend && node copy-dist.js",
    "outputDirectory": "dist",
    "builds": [
        { "src": "backend/server.js", "use": "@vercel/node" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "backend/server.js" },
        { "src": "/assets/(.*)", "dest": "/assets/$1" },
        { "src": "/(.*\\.[a-z]+)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}